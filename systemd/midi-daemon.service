[Unit]
Description=MIDI Lua Routing Daemon (user)
Documentation=https://github.com/yourname/midi-daemon
After=sound.target pipewire.service pipewire-pulse.service

[Service]
Type=simple
ExecStart=%h/.cargo/bin/midi-daemon
ExecReload=/bin/kill -USR1 $MAINPID
Restart=on-failure
RestartSec=2
KillSignal=SIGTERM
TimeoutStopSec=30

StandardOutput=journal
StandardError=journal
Environment=RUST_LOG=midi_daemon=info

[Install]
WantedBy=default.target
